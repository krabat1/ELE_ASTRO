---
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  lang: string;
  image?: string; 
}

const { 
  title = "Alapértelmezett Cím", 
  description = "Alapértelmezett leírás a weboldalról...", 
  lang = "default",
  image
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<SEO
			title={title || "Alapértelmezett Cím"} 
      description={description || "Alapértelmezett leírás..."} 
      lang={lang}
      image={image}/><!--  -->
			<slot name="head" />
	</head>
	<body>
		<slot />
	</body>
</html>
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
