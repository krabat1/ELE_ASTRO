---
import SEO from '../components/SEO.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: 'hu' | 'en' | 'de';
  image?: string;
  collection?: string;
  hrefLang?: string|undefined;
}

const { 
  title = "Alapértelmezett Cím", 
  description = "Alapértelmezett leírás a weboldalról...", 
  lang,
  image,
  collection,
  hrefLang 
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<SEO
			title={title || "Alapértelmezett Cím"} 
			description={description} 
			lang={lang as 'hu' | 'en' | 'de'}
			image={image} />
			<slot name="head" />
	</head>
	<body>
    <LanguageSwitcher 
      lang={lang}
	  collection={collection}
      hrefLang={hrefLang}
    />
		<slot />
	</body>
</html>
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
